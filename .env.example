# ─────────────────────────────────────────────────────────────────────────────
# Sentinel V2 — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker ────────────────────────────────────────────────────────────────────
CONTAINER_NAME=api-service-prod

# ── Telegram (real-time alerts) ───────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── n8n (AI analysis on session close) ────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/sentinel-v2

# ── AbuseIPDB (free tier — 1,000 checks/day + IP reporting) ───────────────────
# Register at https://www.abuseipdb.com/register
# Free tier includes IP check API + abuse reporting
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
